# ── MikroTik ──────────────────────────────────────────────────
USER_MIKROTIK=admin
PASS_MIKROTIK=your_password_here

# ── Google Sheets ─────────────────────────────────────────────
KEY=path/to/your-service-account-key.json
SPREADSHEET_ID=your_google_sheet_id

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DB_NAME=cortes-redmetro
MONGO_OPTIONS_COLLECTION=options

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN_1=http://localhost:5173
CORS_ORIGIN_2=http://localhost:8000

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
